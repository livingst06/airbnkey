# Copier vers .env : cp .env.example .env puis renseigner les valeurs.
# Prisma : datasource PostgreSQL (ex. Supabase) — voir prisma/schema.prisma.
# La CLI lit .env via prisma.config.ts (import dotenv) ; garder DATABASE_URL ici.

# Chaîne de connexion PostgreSQL (Supabase : Project Settings > Database > URI)
# Exemple pooler : postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Optionnel : URL directe (port 5432) pour migrations — doc Supabase + Prisma "directUrl"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.[ref].supabase.co:5432/postgres"

# Variables publiques (exposées au navigateur)
# Optionnel : carte vectorielle MapTiler
# NEXT_PUBLIC_MAPTILER_API_KEY=

# URL canonique publique (prod Vercel)
# NEXT_PUBLIC_SITE_URL=https://airbnkey.vercel.app

# Admin CMS
# NEXT_PUBLIC_ADMIN_MODE=true

# Supabase (upload images depuis le client)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel : upload admin en data URL (hors-ligne / debug)
# NEXT_PUBLIC_IMAGE_UPLOAD_FALLBACK=dataurl

# Après configuration :
# 1) si des positions sont en doublon : pnpm db:backfill-positions
# 2) appliquer le schéma : pnpm db:push
# 3) seed uniquement si la base est vide : pnpm db:seed
