# Copier vers .env.local pour le développement local :
# cp .env.example .env.local
#
# IMPORTANT :
# - dev et prod doivent utiliser des projets Supabase différents
# - ne jamais réutiliser les clés prod en local
# - Prisma CLI lit .env (cf prisma.config.ts). Si vous utilisez .env.local,
#   exportez les variables avant les commandes Prisma, ou dupliquez uniquement
#   les variables DB dans .env local machine.

# ──────────────────────────────────────────────────────────────────────────────
# DEV (localhost)
# ──────────────────────────────────────────────────────────────────────────────
# Chaîne de connexion PostgreSQL DEV (Supabase dev > Project Settings > Database > URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Optionnel : URL directe (port 5432) pour migrations — doc Supabase + Prisma "directUrl"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.[ref].supabase.co:5432/postgres"

# Variables publiques (exposées au navigateur)
# Optionnel : carte vectorielle MapTiler
# NEXT_PUBLIC_MAPTILER_API_KEY=

# URL canonique de l'environnement courant
# DEV: NEXT_PUBLIC_SITE_URL=http://localhost:3000
# PROD: NEXT_PUBLIC_SITE_URL=https://airbnkey.vercel.app
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin whitelist (emails séparés par des virgules, en lowercase recommandé)
# ADMIN_LIST=admin@example.com,owner@example.com

# Supabase DEV (upload + auth sociale)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OAuth Social login
# 1) Côté Google/Facebook/Apple, callback provider = https://<supabase-ref>/auth/v1/callback
# 2) Côté Supabase URL Configuration:
#    - DEV Site URL = http://localhost:3000
#    - DEV Redirect URL = http://localhost:3000/auth/callback
# 3) Côté PROD (Vercel + Supabase prod):
#    - PROD Site URL = https://airbnkey.vercel.app (ou domaine final)
#    - PROD Redirect URL = https://airbnkey.vercel.app/auth/callback

# Optionnel : upload admin en data URL (hors-ligne / debug)
# NEXT_PUBLIC_IMAGE_UPLOAD_FALLBACK=dataurl

# Workflow recommandé (migrations versionnées)
# 1) Créer migration en dev: pnpm db:migrate:dev --name <description>
# 2) Committer prisma/migrations/*
# 3) En prod, appliquer migrations: pnpm db:migrate:deploy
# 4) Seed uniquement si nécessaire: pnpm db:seed
