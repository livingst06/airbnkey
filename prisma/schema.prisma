generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Apartment {
  id          String   @id
  slug        String   @unique
  title       String
  description String
  beds        Int
  bathrooms   Int
  latitude    Float
  longitude   Float
  advantages  Json
  images      Json
  bookingUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
