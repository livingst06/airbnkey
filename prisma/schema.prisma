generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Apartment {
  id          String   @id
  slug        String   @unique
  title       String
  description String
  city        String
  street      String?
  guests      Int      @default(1)
  beds        Int
  bathrooms   Int
  reviewsCount Int?
  ratingAverage Float?
  latitude    Float
  longitude   Float
  advantages  Json
  images      Json
  bookingUrl  String?
  /// Ordre d'affichage (0 = premier). Tri principal côté API.
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([position])
  @@index([position])
}
